{
  "name": "vote",
  "version": "1.4.1",
  "description": "Vote and Random software",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "build-win": "electron-builder --win --x64 --ia32 --publish never"
  },
  "keywords": [
    "vote",
    "random",
    "class"
  ],
  "author": "jwdjk392",
  "license": "MIT",
  "dependencies": {
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "electron-progressbar": "^2.2.1",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "js-confetti": "^0.13.1",
    "sweetalert2": "^11.26.20"
  },
  "devDependencies": {
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "electron-reloader": "^1.2.3"
  },
  "build": {
    "appId": "com.jwdjk392.voteandrandom",
    "productName": "투표및 뽑기 프로그램",
    "mac": {
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "artifactName": "vote-setup-${version}.${ext}",
      "license": "build/license.html"
    }
  }
}
